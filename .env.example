# =============================================================================
# Vitrê — variáveis de ambiente (template)
# Copie para .env.local e preencha com seus valores reais.
# .env.local está no .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# -----------------------------------------------------------------------------
# Supabase Postgres (DB)
# -----------------------------------------------------------------------------
# DATABASE_URL: pooler PgBouncer transaction mode — porta 6543
#   Use em runtime (Next server actions, route handlers).
# DIRECT_URL:   conexão direta — porta 5432
#   Use em migrations (drizzle-kit) e seeds.
DATABASE_URL=postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# -----------------------------------------------------------------------------
# Supabase Storage + client
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon_key>
SUPABASE_SERVICE_ROLE_KEY=<service_role_key>

# -----------------------------------------------------------------------------
# Better Auth
# -----------------------------------------------------------------------------
# BETTER_AUTH_SECRET: gerar com `openssl rand -base64 32`
# baseURL é derivada de NEXT_PUBLIC_APP_URL para evitar divergência client/server
BETTER_AUTH_SECRET=

# Google OAuth (opcional na Fase 1 — pode ficar vazio)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Resend (email transacional)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_<...>
RESEND_FROM_EMAIL=onboarding@resend.dev

# -----------------------------------------------------------------------------
# Upstash Redis (rate limit)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://<region>-<id>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<token>

# -----------------------------------------------------------------------------
# Vercel Cron (proteção do endpoint /api/cron/keep-alive)
# -----------------------------------------------------------------------------
# CRON_SECRET: gerar com `openssl rand -hex 32`
CRON_SECRET=

# -----------------------------------------------------------------------------
# Healthcheck detail gate (gate H3 — auditoria 2026-05-11)
# -----------------------------------------------------------------------------
# HEALTH_SECRET: opcional. Sem ele, /api/health retorna só { ok, db, timestamp,
# elapsedMs }. Com ele, request com header `X-Health-Secret: <valor>` libera
# detalhe { role, bypassrls } pra smoke pós-deploy T1-1.
# Gerar com `openssl rand -hex 32`.
HEALTH_SECRET=

# -----------------------------------------------------------------------------
# Sentry (observabilidade — opcional em dev local)
# -----------------------------------------------------------------------------
# DSN: pegar no dashboard Sentry > Settings > Projects > <projeto> > Client Keys.
# NEXT_PUBLIC_SENTRY_DSN deve ser o MESMO valor (Sentry SDK no client lê via NEXT_PUBLIC_*).
# Se vazios em dev, Sentry vira no-op (sem envio).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# NEXT_PUBLIC_SENTRY_ENVIRONMENT é lido no client bundle (Sentry browser SDK).
# Geralmente mesma string de SENTRY_ENVIRONMENT.
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
