{
  "name": "mangos-pay",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "description": "Mangos Pay — SaaS de loja online com checkout WhatsApp",
  "//": "TODO: migrar next lint para ESLint CLI antes do Next 16. Ver docs/issues/next16-eslint-cli.md",
  "scripts": {
    "//dev": "Em Windows com path c/ espaços, `node --max-old-space-size=N ./node_modules/...` quebra (spawn UNKNOWN). Se aparecer OOM 'MemoryChunk allocation failed' no Turbopack worker (FATAL 2026-05-27), rodar PowerShell antes: $env:NODE_OPTIONS = '--max-old-space-size=4096'; npm run dev",
    "dev": "next dev --turbopack",
    "prebuild": "node scripts/stamp-sw.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "tsx --test \"tests/**/*.test.ts\"",
    "test:integration": "tsx --test \"tests/integration/**/*.test.ts\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:check": "tsx scripts/check-db.ts",
    "db:check-storage": "tsx scripts/check-storage.ts",
    "db:check-anon": "node scripts/check-anon-grants.mjs",
    "db:check-sql": "tsx scripts/check-sql-applied.mjs",
    "db:audit": "tsx scripts/full-audit.mjs",
    "db:apply": "tsx scripts/apply-sql.ts",
    "db:smoke-idor": "node --env-file=.env.local scripts/smoke-idor.mjs",
    "db:audit-definer": "node --env-file=.env.local scripts/audit-security-definer.mjs",
    "pwa:icons": "node scripts/generate-pwa-icons.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@sentry/nextjs": "^10.52.0",
    "@supabase/supabase-js": "^2.45.6",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.3",
    "better-auth": "^1.2.12",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "import-in-the-middle": "^3.0.1",
    "libphonenumber-js": "^1.11.14",
    "lucide-react": "^0.525.0",
    "nanoid": "^5.0.9",
    "next": "^15.5.0",
    "pg": "^8.16.3",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-easy-crop": "^5.5.7",
    "react-hook-form": "^7.75.0",
    "react-number-format": "^5.4.4",
    "recharts": "^3.8.1",
    "require-in-the-middle": "^8.0.1",
    "resend": "^4.0.1",
    "sharp": "^0.33.5",
    "slugify": "^1.6.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.15.4",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.1.0",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9",
    "eslint-config-next": "^15.5.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4",
    "tsx": "^4.20.3",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5"
  },
  "pnpm": {
    "overrides": {
      "import-in-the-middle": "3.0.1"
    }
  }
}
